{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/apex_loop.py session-start --host claude --route default",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/apex_loop.py user-prompt-submit --host claude --route default",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Shell|PowerShell|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/apex_loop.py pre-tool-use --host claude --route safety",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/apex_loop.py post-tool-use --host claude --route edit",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Bash|Shell|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/apex_loop.py post-tool-use --host claude --route bash",
            "timeout": 30
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/apex_loop.py post-tool-use --host claude --route always",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/apex_loop.py stop --host claude --route default",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
