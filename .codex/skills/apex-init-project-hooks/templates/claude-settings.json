{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py -3 \".claude/hooks/apex_loop.py\" session-start --host claude --route default",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py -3 \".claude/hooks/apex_loop.py\" user-prompt-submit --host claude --route default",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py -3 \".claude/hooks/apex_loop.py\" pre-tool-use --host claude --route safety-write",
            "timeout": 30
          }
        ],
        "matcher": "Edit|Write|MultiEdit"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "py -3 \".claude/hooks/apex_loop.py\" pre-tool-use --host claude --route safety-read",
            "timeout": 30
          }
        ],
        "matcher": "Read|Grep|Glob|mcp__.*"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "py -3 \".claude/hooks/apex_loop.py\" pre-tool-use --host claude --route safety-shell",
            "timeout": 30
          }
        ],
        "matcher": "Bash|Shell|PowerShell"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py -3 \".claude/hooks/apex_loop.py\" post-tool-use --host claude --route edit",
            "timeout": 30
          }
        ],
        "matcher": "Edit|Write|MultiEdit"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "py -3 \".claude/hooks/apex_loop.py\" post-tool-use --host claude --route bash",
            "timeout": 30
          }
        ],
        "matcher": "Bash|Shell|PowerShell"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "py -3 \".claude/hooks/apex_loop.py\" post-tool-use --host claude --route always",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolBatch": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py -3 \".claude/hooks/apex_loop.py\" post-tool-batch --host claude --route default",
            "timeout": 30
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py -3 \".claude/hooks/apex_loop.py\" pre-compact --host claude --route default",
            "timeout": 30
          }
        ],
        "matcher": "auto|manual"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py -3 \".claude/hooks/apex_loop.py\" stop --host claude --route default",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
